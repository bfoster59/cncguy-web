---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SectionEnd from '../components/SectionEnd.astro';
---
<Layout title="Notify me — CNCGuy" description="Get notified when new CNC Guy products ship.">
  <Nav />

  <main>
    <section class="notify-hero grid-bg">
      <div class="container notify-inner">
        <span class="eyebrow-line">Coming Soon</span>
        <h1 class="notify-title">We'll let you know.</h1>
        <p class="notify-sub">
          Drop your email and we'll send a single message when the product you're watching ships. No newsletter, no drip campaign, no resale.
        </p>

        <form
          class="notify-form"
          id="notify-form"
          action="/api/subscribe"
          method="post"
          novalidate
        >
          <input type="email" name="email" placeholder="you@shop.com" required aria-label="Email address" />
          <button type="submit" class="cta-primary">Notify me</button>
        </form>
        <p class="notify-status" id="notify-status" role="status" aria-live="polite"></p>

        <p class="notify-fine">
          CNCGuy Studio — shop-floor suite, coming 2026.<br/>
          DNCGuy — file transfer to machines, in development.
        </p>

        <div class="notify-back">
          <a href="/" class="btn-secondary">← Back to all products</a>
        </div>
      </div>
      <SectionEnd code="M30" />
    </section>
  </main>

  <Footer />
</Layout>

<script is:inline>
  (function () {
    var form = document.getElementById('notify-form');
    var status = document.getElementById('notify-status');
    if (!form || !status) return;
    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      var input = form.querySelector('input[name="email"]');
      var btn = form.querySelector('button[type="submit"]');
      var email = (input && input.value || '').trim();
      status.classList.remove('is-error', 'is-ok');
      if (!email) { status.textContent = 'Please enter an email.'; status.classList.add('is-error'); return; }
      btn.disabled = true;
      var originalLabel = btn.textContent;
      btn.textContent = 'Sending...';
      try {
        var res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ email: email }),
        });
        var data = await res.json().catch(function () { return {}; });
        if (res.ok && data && data.ok) {
          form.style.display = 'none';
          status.textContent = "Thanks — we'll send one message when the product you're watching ships.";
          status.classList.add('is-ok');
        } else {
          status.textContent = (data && data.error) || 'Could not subscribe right now. Try again in a moment.';
          status.classList.add('is-error');
          btn.disabled = false;
          btn.textContent = originalLabel;
        }
      } catch (err) {
        status.textContent = 'Network error. Try again in a moment.';
        status.classList.add('is-error');
        btn.disabled = false;
        btn.textContent = originalLabel;
      }
    });
  })();
</script>

<style>
  .notify-hero {
    padding: 96px 0 120px;
    border-bottom: 1px solid var(--line-1);
    min-height: calc(100vh - 200px);
  }
  .notify-inner {
    max-width: 640px;
    text-align: center;
    margin: 0 auto;
  }
  .notify-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(40px, 5vw, 56px);
    line-height: 1.04;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: var(--fg-1);
    margin: 22px 0 20px;
  }
  .notify-sub {
    font-size: 18px;
    color: var(--fg-2);
    line-height: 1.55;
    margin: 0 auto 36px;
    max-width: 540px;
  }
  .notify-form {
    display: flex;
    gap: 10px;
    justify-content: center;
    max-width: 480px;
    margin: 0 auto 28px;
  }
  .notify-form input {
    flex: 1;
    background: var(--bg-2);
    border: 1px solid var(--line-2);
    border-radius: var(--radius-md);
    padding: 14px 16px;
    color: var(--fg-1);
    font-family: var(--font-body);
    font-size: 15px;
    transition: border-color var(--dur-fast) var(--ease-std),
                box-shadow var(--dur-med) var(--ease-std);
  }
  .notify-form input::placeholder { color: var(--fg-4); }
  .notify-form input:focus {
    outline: none;
    border-color: var(--cnc-accent);
    box-shadow: 0 0 0 3px var(--cnc-accent-glow-soft);
  }
  .notify-status {
    margin: 14px auto 0;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--fg-3);
    min-height: 1em;
    max-width: 520px;
  }
  .notify-status.is-ok { color: var(--cnc-accent); }
  .notify-status.is-error { color: #ff6b6b; }
  .notify-fine {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-4);
    line-height: 2;
    margin: 32px auto 0;
  }
  .notify-back {
    margin-top: 40px;
  }
  @media (max-width: 900px) {
    .notify-hero { padding: 56px 0 72px; }
    .notify-title { font-size: 40px; }
    .notify-sub { font-size: 16px; }
    .notify-form { flex-direction: column; }
  }
</style>
