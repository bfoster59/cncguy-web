---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SectionEnd from '../components/SectionEnd.astro';

const products = [
  {
    chip: 'Beta · Shipping',
    title: 'CNCGuy Edit',
    body: 'G-code editor with live backplot. Fanuc, Mazak, Haas.',
    cta: 'Learn more →',
    href: '/edit',
    chipAccent: true,
  },
  {
    chip: 'Coming 2026',
    title: 'CNCGuy Studio',
    body: 'Shop-floor suite. Jobs, setups, tooling, revision control.',
    cta: 'Notify me →',
    href: '/notify',
    chipAccent: false,
  },
  {
    chip: 'In Development',
    title: 'DNCGuy',
    body: 'File transfer to machines. Drip-feed, serial, ethernet.',
    cta: 'Notify me →',
    href: '/notify',
    chipAccent: false,
  },
];

const whatYouGet = [
  {
    title: 'Modern tools',
    body: 'Monaco editor, fast open, canvas backplot. Works with compact Fanuc syntax out of the box.',
  },
  {
    title: "Made by someone who's run them",
    body: "Not a software company with a machining-adjacent demo. A machinist's tool, period.",
  },
  {
    title: 'Honest pricing',
    body: 'Free beta now. Fair Pro pricing later. Never the thousand-dollar-a-seat kind of fair.',
  },
];
---
<Layout title="CNCGuy — Machined With Experience" description="Precision machining apps built by a 45-year aerospace veteran. Calculators, references, and software that actually work the way machinists think — because they were built by one.">
  <Nav />

  <main>
    <section class="home-hero grid-bg">
      <div class="container home-hero-inner">
        <span class="eyebrow-line">Machined With Experience · Est. 1981</span>
        <h1 class="home-hero-title">Tools Built <span class="accent">For The Shop Floor.</span></h1>
        <p class="home-hero-sub">Precision machining apps built by a 45-year aerospace veteran. Calculators, references, and software that actually work the way machinists think — because they were built by one.</p>
        <div class="home-hero-ctas">
          <a href="/edit" class="cta-primary">Download CNCGuy Edit →</a>
          <a href="#products" class="btn-secondary">See all products →</a>
        </div>

        <div class="chrome home-hero-shot">
          <div class="chrome-bar">
            <div class="chrome-dots"><span></span><span></span><span></span></div>
            <div class="chrome-title">CNCGuy Edit [Beta] · 660-104485-G71.cnc</div>
          </div>
          <img src="/cncguy-edit-screenshot.png" alt="CNCGuy Edit — G-code editor with live backplot" />
        </div>
      </div>
      <SectionEnd code="M01" />
    </section>

    <section class="home-products" id="products">
      <div class="container">
        <div class="section-heading">
          <span class="eyebrow-line">01 · Products</span>
          <h2>Four decades of shop-floor experience, turned into incredible software.</h2>
          <p>Use what you need. <a href="/workbench" class="inline-link">See the full workbench →</a></p>
        </div>

        <div class="products-grid">
          {products.map((p) => (
            <a href={p.href} class="product-card">
              <div class={"chip " + (p.chipAccent ? "chip-accent" : "chip-neutral")}>{p.chip}</div>
              <h3>{p.title}</h3>
              <p>{p.body}</p>
              <div class="product-cta">{p.cta}</div>
            </a>
          ))}
        </div>
      </div>
      <SectionEnd code="M01" />
    </section>

    <section class="home-story" id="story">
      <div class="container story-inner">
        <div class="story-copy">
          <span class="eyebrow-line">The Story</span>
          <h2 class="story-title">Forty-five years on the floor.</h2>
          <p class="story-body">
            I moved to Houston in 1981 because the steel industry tanked in
            Northwest Indiana and I was an unemployed heavy-equipment operator.
            The oil field was booming, so I packed it in and headed south. I
            landed in the machine shop of a tubular-products manufacturer
            running a band saw, cutting raw material for the die shop.
          </p>
          <p class="story-body">
            A few weeks in, they trusted me on mills and lathes — all manual.
            Then they bought a Mazak M1 retrofitted with a Fanuc 6T control,
            and nobody wanted to touch it. <em>Except me.</em> I worked every
            minute I could on that machine, often for free, until I owned it.
            That was the beginning.
          </p>
          <p class="story-body">
            From there I couldn't be stopped. Five years at a Houston shop with
            twelve CNC lathes — Mori, Hess, McDonnell Douglas tape controls —
            gave me serious depth. When the Houston bottom dropped out in 1986
            I hightailed it back to Indiana and landed in a Chicago gear shop:
            CNC lathes, CNC mills, hobbing, shaping, broaching. Another huge
            exposure. In 2000 I moved into aerospace as a CNC programmer, which
            I'd been doing on my own programs for years anyway.
          </p>
          <p class="story-body">
            I've programmed mills, lathes, and multi-axis machines, set up
            cells, maintained AS9100 compliance, and trained more machinists
            and programmers than I can count. Every tool that makes it onto
            this site exists because I needed it — or remember needing it —
            to support a real job or fill a real need.
          </p>
          <blockquote class="story-pull">
            If it doesn't work on the shop floor, it doesn't ship.
          </blockquote>
          <p class="story-body">
            I've always been fascinated with code — Visual Basic, C++, Python —
            and I started building tools for myself on the side. Eventually
            those tools were good enough that other machinists kept asking for
            them. CNC Guy is what I want for the industry: useful, affordable
            software built by someone who's actually run the machines. It
            starts with <strong>CNCGuy Edit</strong>. I hope you find it
            useful — feedback is always welcome.
          </p>
        </div>

        <div class="story-side">
          <div class="story-stats" aria-label="Credentials">
            <div class="stat">
              <div class="stat-num">45<span class="stat-plus">+</span></div>
              <div class="stat-label">Years on the floor</div>
            </div>
            <div class="stat-rule" aria-hidden="true"></div>
            <div class="stat">
              <div class="stat-num stat-num-text">AS9100</div>
              <div class="stat-label">Aerospace quality trained</div>
            </div>
          </div>

          <figure class="story-photo">
            <img src="/founder-bob.jpg" alt="Bob Foster, founder of CNC Guy, at a DMG Mori MSX-500III lathe control" width="880" height="880" loading="lazy" decoding="async" />
            <figcaption class="story-photo-cap">Bob Foster · CNC Guy founder</figcaption>
          </figure>
        </div>
      </div>
      <SectionEnd code="M01" />
    </section>

    <section class="home-features">
      <div class="container">
        <div class="section-heading">
          <span class="eyebrow-line">02 · What You Get</span>
          <h2>Three things other tools miss.</h2>
        </div>

        <div class="wyg-grid">
          {whatYouGet.map((w, i) => (
            <div class="wyg-tile">
              <div class="feat-num">0{i + 1}</div>
              <h3>{w.title}</h3>
              <p>{w.body}</p>
            </div>
          ))}
        </div>
      </div>
      <SectionEnd code="M01" />
    </section>

    <section class="home-download" id="download">
      <div class="container home-download-inner">
        <span class="eyebrow-line">03 · Free Beta · Windows</span>
        <h2 class="home-download-title">Try CNCGuy Edit today.</h2>
        <p class="home-download-sub">No account, no email. Free through October 2026.</p>
        <a href="/edit#download" class="cta-primary large">Download CNCGuy Edit →</a>
        <p class="home-download-meta">v0.9 Beta · Windows 10/11 · 48 MB</p>
      </div>
      <SectionEnd code="M00" />
    </section>

    <section class="home-notify">
      <div class="container home-notify-inner">
        <h3 class="home-notify-title">Get notified when Pro ships.</h3>
        <form class="home-notify-form" id="home-notify-form" action="/api/subscribe" method="post" novalidate>
          <input type="email" name="email" placeholder="you@shop.com" required aria-label="Email address" />
          <button type="submit" class="btn-secondary">Notify me</button>
        </form>
        <p class="home-notify-status" id="home-notify-status" role="status" aria-live="polite"></p>
      </div>
      <SectionEnd code="M30" />
    </section>

    <script is:inline>
      (function () {
        var form = document.getElementById('home-notify-form');
        var status = document.getElementById('home-notify-status');
        if (!form || !status) return;
        form.addEventListener('submit', async function (e) {
          e.preventDefault();
          var input = form.querySelector('input[name="email"]');
          var btn = form.querySelector('button[type="submit"]');
          var email = (input && input.value || '').trim();
          status.classList.remove('is-error', 'is-ok');
          if (!email) { status.textContent = 'Please enter an email.'; status.classList.add('is-error'); return; }
          btn.disabled = true;
          var originalLabel = btn.textContent;
          btn.textContent = 'Sending...';
          try {
            var res = await fetch('/api/subscribe', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ email: email }),
            });
            var data = await res.json().catch(function () { return {}; });
            if (res.ok && data && data.ok) {
              form.style.display = 'none';
              status.textContent = "Thanks — we'll send one message when Pro ships.";
              status.classList.add('is-ok');
            } else {
              status.textContent = (data && data.error) || 'Could not subscribe right now. Try again in a moment.';
              status.classList.add('is-error');
              btn.disabled = false;
              btn.textContent = originalLabel;
            }
          } catch (err) {
            status.textContent = 'Network error. Try again in a moment.';
            status.classList.add('is-error');
            btn.disabled = false;
            btn.textContent = originalLabel;
          }
        });
      })();
    </script>
  </main>

  <Footer />
</Layout>

<style>
  main {
    background: var(--bg-1);
  }
  .home-hero {
    padding: 104px 0 88px;
    border-bottom: 1px solid var(--line-1);
    position: relative;
    overflow: hidden;
  }
  /* Subtle radial wash — a hint of warmth above the fold without a banner */
  .home-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 40% at 50% 0%, rgba(217,96,31,0.10), transparent 70%),
      radial-gradient(ellipse 80% 50% at 50% 100%, rgba(217,96,31,0.04), transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  .home-hero-inner {
    text-align: center;
    position: relative;
    z-index: 1;
  }
  .home-hero-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(48px, 6.5vw, 68px);
    line-height: 1.02;
    letter-spacing: -0.015em;
    text-transform: uppercase;
    color: var(--fg-1);
    margin: 24px 0 20px;
  }
  .home-hero-title .accent {
    color: var(--cnc-accent);
    text-shadow: 0 0 28px var(--cnc-accent-glow);
  }
  .home-hero-sub {
    font-size: 19px;
    color: var(--fg-2);
    max-width: 640px;
    margin: 0 auto 36px;
    line-height: 1.5;
  }
  .home-hero-ctas {
    display: inline-flex;
    gap: 14px;
    margin-bottom: 64px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .home-hero-shot {
    max-width: 1040px;
    margin: 0 auto;
  }
  .home-products {
    padding: clamp(72px, 10vw, 120px) 0;
  }
  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .product-card {
    background: var(--bg-2);
    border: 1px solid var(--line-2);
    border-radius: var(--radius-md);
    padding: 28px 26px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    text-decoration: none;
    color: inherit;
    position: relative;
    transition: border-color var(--dur-med) var(--ease-std),
                transform var(--dur-med) var(--ease-std),
                box-shadow var(--dur-med) var(--ease-std),
                background var(--dur-med) var(--ease-std);
  }
  /* Orange thread #7 — product card hover crosses to orange border + glow */
  .product-card:hover {
    border-color: var(--cnc-accent);
    transform: translateY(-3px);
    background: linear-gradient(180deg, var(--bg-3), var(--bg-2));
    box-shadow:
      var(--shadow-raise),
      0 0 0 1px var(--cnc-accent-tint);
  }
  .product-card h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--fg-1);
    margin: 0;
    transition: color var(--dur-med) var(--ease-std);
  }
  .product-card:hover h3 { color: var(--cnc-accent); }
  .product-card p {
    font-size: 15px;
    line-height: 1.55;
    color: var(--fg-3);
    margin: 0;
    flex: 1;
  }
  .product-cta {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--fg-2);
    margin-top: 8px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: color var(--dur-med) var(--ease-std), gap var(--dur-med) var(--ease-out);
  }
  .product-card:hover .product-cta {
    color: var(--cnc-accent);
    gap: 10px;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 4px 9px 3px;
    border-radius: var(--radius-xs);
    align-self: flex-start;
  }
  .chip-accent {
    color: var(--cnc-accent);
    border: 1px solid var(--cnc-accent);
    background: rgba(217, 96, 31, 0.06);
  }
  .chip-neutral {
    color: var(--fg-3);
    border: 1px solid var(--line-2);
    background: var(--bg-3);
  }
  .home-story {
    padding: clamp(72px, 10vw, 120px) 0;
    border-top: 1px solid var(--line-1);
  }
  .story-inner {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 56px;
    align-items: start;
  }
  .story-side {
    display: flex;
    flex-direction: column;
    gap: 24px;
    position: sticky;
    top: 96px;
  }
  .story-photo {
    margin: 0;
    width: 100%;
    aspect-ratio: 1 / 1;
    border: 1px solid var(--line-2);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--bg-2);
    position: relative;
    box-shadow:
      0 1px 0 var(--surface-edge-hi) inset,
      var(--shadow-raise),
      0 0 0 1px var(--cnc-accent-rule);
    transition: box-shadow var(--dur-med) var(--ease-std),
                transform var(--dur-med) var(--ease-std);
  }
  .story-photo:hover {
    transform: translateY(-2px);
    box-shadow:
      0 1px 0 var(--surface-edge-hi) inset,
      var(--shadow-frame),
      0 0 0 1px var(--cnc-accent),
      0 0 24px var(--cnc-accent-glow-soft);
  }
  .story-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 30% 40%;
    display: block;
    filter: saturate(1.05) contrast(1.02);
  }
  /* Caption appears on the photo's bottom — mono, small, like an equipment tag */
  .story-photo-cap {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    padding: 10px 14px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fg-1);
    background: linear-gradient(180deg, transparent, rgba(0,0,0,0.65) 60%);
  }
  /* Orange corner brackets — same kinetic mark we use elsewhere */
  .story-photo::before,
  .story-photo::after {
    content: "";
    position: absolute;
    width: 14px; height: 14px;
    border: 1px solid var(--cnc-accent);
    opacity: 0.85;
    pointer-events: none;
    z-index: 2;
  }
  .story-photo::before { top: -1px; left: -1px; border-right: none; border-bottom: none; }
  .story-photo::after  { bottom: -1px; right: -1px; border-left: none; border-top: none; }
  .story-copy { max-width: 640px; }
  .story-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(34px, 4.4vw, 56px);
    line-height: 1.04;
    letter-spacing: -0.005em;
    text-transform: uppercase;
    color: var(--fg-1);
    margin: 14px 0 24px;
  }
  .story-body {
    font-size: 17px;
    line-height: 1.6;
    color: var(--fg-2);
    margin: 0 0 24px;
  }
  .story-pull {
    margin: 28px 0;
    padding: 6px 0 6px 18px;
    border-left: 3px solid var(--cnc-accent);
    font-family: var(--font-display);
    font-weight: 600;
    text-transform: uppercase;
    color: var(--cnc-accent);
    font-size: clamp(18px, 2vw, 24px);
    letter-spacing: 0.01em;
    line-height: 1.2;
  }

  .story-stats {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--line-2);
    border-radius: var(--radius-md);
    background: linear-gradient(180deg, var(--bg-2), var(--bg-3));
    padding: 28px 28px;
    box-shadow: var(--shadow-card);
  }
  .stat {
    padding: 10px 0;
    text-align: center;
  }
  .stat-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(56px, 6vw, 84px);
    line-height: 0.95;
    letter-spacing: -0.01em;
    color: var(--cnc-accent);
    text-shadow: 0 0 28px var(--cnc-accent-glow);
  }
  .stat-num-text {
    font-size: clamp(40px, 4.6vw, 64px);
  }
  .stat-plus {
    font-size: 0.7em;
    margin-left: 2px;
    color: var(--cnc-accent);
  }
  .stat-label {
    margin-top: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fg-3);
  }
  .stat-rule {
    height: 1px;
    background: var(--line-2);
    margin: 6px 0;
  }
  .home-features {
    padding: clamp(72px, 10vw, 120px) 0;
    border-top: 1px solid var(--line-1);
  }
  .wyg-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .wyg-tile {
    padding: 4px 0;
    border-top: 1px solid var(--line-1);
    padding-top: 24px;
    position: relative;
  }
  /* A small orange tick at the top of each tile — TNRCalc-style kinetic mark */
  .wyg-tile::before {
    content: "";
    position: absolute;
    top: -1px; left: 0;
    width: 32px; height: 1px;
    background: var(--cnc-accent);
    box-shadow: 0 0 6px var(--cnc-accent-glow);
  }
  .wyg-tile h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--fg-1);
    margin: 8px 0 10px;
  }
  .wyg-tile p {
    font-size: 15px;
    line-height: 1.55;
    color: var(--fg-3);
    margin: 0;
  }
  .wyg-tile .feat-num {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.24em;
    color: var(--cnc-accent);
    text-transform: uppercase;
  }
  /* ---- Download CTA strip — primary action repeated as a dedicated band ---- */
  .home-download {
    padding: clamp(72px, 10vw, 120px) 0;
    border-top: 1px solid var(--line-1);
    position: relative;
    overflow: hidden;
    background: var(--bg-1);
  }
  .home-download::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 50% 40% at 50% 50%, rgba(217,96,31,0.10), transparent 70%);
    pointer-events: none;
  }
  .home-download-inner {
    text-align: center;
    position: relative;
    z-index: 1;
    max-width: 720px;
  }
  .home-download-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(36px, 4.6vw, 56px);
    line-height: 1.04;
    letter-spacing: -0.005em;
    text-transform: uppercase;
    color: var(--fg-1);
    margin: 18px 0 14px;
  }
  .home-download-sub {
    font-size: 17px;
    color: var(--fg-2);
    line-height: 1.55;
    margin: 0 auto 28px;
    max-width: 540px;
  }
  .home-download-meta {
    margin-top: 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fg-4);
  }

  .home-notify {
    padding: 56px 0 72px;
    border-top: 1px solid var(--line-1);
    background: var(--bg-0);
  }
  .home-notify-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }
  .home-notify-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--fg-1);
    margin: 0;
  }
  .home-notify-form {
    display: flex;
    gap: 10px;
    align-items: stretch;
  }
  .home-notify-form input {
    background: var(--bg-2);
    border: 1px solid var(--line-2);
    border-radius: var(--radius-md);
    padding: 12px 16px;
    color: var(--fg-1);
    font-family: var(--font-body);
    font-size: 14px;
    min-width: 260px;
    transition: border-color var(--dur-fast) var(--ease-std),
                box-shadow var(--dur-med) var(--ease-std);
  }
  .home-notify-form input::placeholder { color: var(--fg-4); }
  .home-notify-form input:focus {
    outline: none;
    border-color: var(--cnc-accent);
    box-shadow: 0 0 0 3px var(--cnc-accent-glow-soft);
  }
  .home-notify-status {
    margin: 14px 0 0;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--fg-3);
    min-height: 1em;
  }
  .home-notify-status.is-ok { color: var(--cnc-accent); }
  .home-notify-status.is-error { color: #ff6b6b; }
  @media (max-width: 900px) {
    .home-hero { padding: 48px 0 56px; }
