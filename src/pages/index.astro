---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const products = [
  {
    chip: 'Beta · Shipping',
    title: 'CNCGuy Edit',
    body: 'G-code editor with live backplot. Fanuc, Mazak, Haas.',
    cta: 'Learn more →',
    href: '/edit',
    chipAccent: true,
  },
  {
    chip: 'Coming 2026',
    title: 'CNCGuy Studio',
    body: 'Shop-floor suite. Jobs, setups, tooling, revision control.',
    cta: 'Notify me →',
    href: '/notify',
    chipAccent: false,
  },
  {
    chip: 'In Development',
    title: 'DNCGuy',
    body: 'File transfer to machines. Drip-feed, serial, ethernet.',
    cta: 'Notify me →',
    href: '/notify',
    chipAccent: false,
  },
];

const whatYouGet = [
  {
    title: 'Modern tools',
    body: 'Monaco editor, fast open, canvas backplot. Works with compact Fanuc syntax out of the box.',
  },
  {
    title: "Made by someone who's run them",
    body: "Not a software company with a machining-adjacent demo. A machinist's tool, period.",
  },
  {
    title: 'Honest pricing',
    body: 'Free beta now. Fair Pro pricing later. Never the thousand-dollar-a-seat kind of fair.',
  },
];
---
<Layout title="CNCGuy — Machined From Experience" description="Precision machining tools and apps built by a machinist with 45 years at the bench.">
  <Nav />

  <main>
    <section class="home-hero grid-bg">
      <div class="container home-hero-inner">
        <span class="eyebrow-line">CNC Guy · Est 1981</span>
        <h1 class="home-hero-title">Machined <span class="accent">From Experience.</span></h1>
        <p class="home-hero-sub">Precision tools for CNC machinists. Built on shop floors, tested on shop floors.</p>
        <div class="home-hero-ctas">
          <a href="/edit" class="cta-primary">Download CNCGuy Edit [Beta]</a>
          <a href="#products" class="btn-secondary">See all products →</a>
        </div>

        <div class="chrome home-hero-shot">
          <div class="chrome-bar">
            <div class="chrome-dots"><span></span><span></span><span></span></div>
            <div class="chrome-title">CNCGuy Edit [Beta] · 660-104485-G71.cnc</div>
          </div>
          <img src="/cncguy-edit-screenshot.png" alt="CNCGuy Edit — G-code editor with live backplot" />
        </div>
      </div>
    </section>

    <section class="home-products" id="products">
      <div class="container">
        <div class="section-heading">
          <span class="eyebrow-line">01 · Products</span>
          <h2>Four decades of shop-floor gripes, turned into software.</h2>
          <p>Use what you need. <a href="/workbench" class="inline-link">See the full workbench →</a></p>
        </div>

        <div class="products-grid">
          {products.map((p) => (
            <a href={p.href} class="product-card">
              <div class={"chip " + (p.chipAccent ? "chip-accent" : "chip-neutral")}>{p.chip}</div>
              <h3>{p.title}</h3>
              <p>{p.body}</p>
              <div class="product-cta">{p.cta}</div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="home-story" id="story">
      <div class="container story-inner">
        <div class="story-copy">
          <span class="eyebrow-line">The Story</span>
          <h2 class="story-title">Forty-five years. One goal.</h2>
          <p class="story-body">
            I started running a Bridgeport in 1981. I've programmed 5-axis mills,
            set up grind cells, signed off on AS9100 audits, and trained more
            apprentices than I can count. Every tool on this site exists because
            I needed it on a real job and couldn't find one that got it right.
          </p>
          <blockquote class="story-pull">
            If it doesn't work on the shop floor, it doesn't ship.
          </blockquote>
          <p class="story-body">
            CNC Guy isn't a software company run by web developers. It's a
            toolbox built by a machinist, for machinists. New apps ship when
            they're ready — not when a roadmap says so.
          </p>
        </div>

        <div class="story-stats" aria-label="Credentials">
          <div class="stat">
            <div class="stat-num">45<span class="stat-plus">+</span></div>
            <div class="stat-label">Years on the floor</div>
          </div>
          <div class="stat-rule" aria-hidden="true"></div>
          <div class="stat">
            <div class="stat-num stat-num-text">AS9100</div>
            <div class="stat-label">Aerospace quality trained</div>
          </div>
        </div>
      </div>
    </section>

    <section class="home-features">
      <div class="container">
        <div class="section-heading">
          <span class="eyebrow-line">02 · What You Get</span>
          <h2>Three things other tools miss.</h2>
        </div>

        <div class="wyg-grid">
          {whatYouGet.map((w, i) => (
            <div class="wyg-tile">
              <div class="feat-num">0{i + 1}</div>
              <h3>{w.title}</h3>
              <p>{w.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="home-notify">
      <div class="container home-notify-inner">
        <h3 class="home-notify-title">Get notified when Pro ships.</h3>
        <form class="home-notify-form" action="/api/subscribe" method="post" onsubmit="event.preventDefault(); alert('Subscribe endpoint not yet wired — your email was not saved. Check back after launch.');">
          <input type="email" name="email" placeholder="you@shop.com" required />
          <button type="submit" class="btn-secondary">Notify me</button>
        </form>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  main {
    background: var(--bg-1);
  }
  .home-hero {
    padding: 104px 0 88px;
    border-bottom: 1px solid var(--line-1);
    position: relative;
    overflow: hidden;
  }
  /* Subtle radial wash — a hint of warmth above the fold without a banner */
  .home-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 40% at 50% 0%, rgba(217,96,31,0.10), transparent 70%),
      radial-gradient(ellipse 80% 50% at 50% 100%, rgba(217,96,31,0.04), transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  .home-hero-inner {
    text-align: center;
    position: relative;
    z-index: 1;
  }
  .home-hero-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(48px, 6.5vw, 68px);
    line-height: 1.02;
    letter-spacing: -0.015em;
    text-transform: uppercase;
    color: var(--fg-1);
    margin: 24px 0 20px;
  }
  .home-hero-title .accent {
    color: var(--cnc-accent);
    text-shadow: 0 0 28px var(--cnc-accent-glow);
  }
  .home-hero-sub {
    font-size: 19px;
    color: var(--fg-2);
    max-width: 640px;
    margin: 0 auto 36px;
    line-height: 1.5;
  }
  .home-hero-ctas {
    display: inline-flex;
    gap: 14px;
    margin-bottom: 64px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .home-hero-shot {
    max-width: 1040px;
    margin: 0 auto;
  }
  .home-products {
    padding: clamp(72px, 10vw, 120px) 0;
  }
  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .product-card {
    background: var(--bg-2);
    border: 1px solid var(--line-2);
    border-radius: var(--radius-md);
    padding: 28px 26px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    text-decoration: none;
    color: inherit;
    position: relative;
    transition: border-color var(--dur-med) var(--ease-std),
                transform var(--dur-med) var(--ease-std),
                box-shadow var(--dur-med) var(--ease-std),
                background var(--dur-med) var(--ease-std);
  }
  /* Orange thread #7 — product card hover crosses to orange border + glow */
  .product-card:hover {
    border-color: var(--cnc-accent);
    transform: translateY(-3px);
    background: linear-gradient(180deg, var(--bg-3), var(--bg-2));
    box-shadow:
      0 16px 40px rgba(0,0,0,0.55),
      0 0 0 1px var(--cnc-accent-tint);
  }
  .product-card h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--fg-1);
    margin: 0;
    transition: color var(--dur-med) var(--ease-std);
  }
  .product-card:hover h3 { color: var(--cnc-accent); }
  .product-card p {
    font-size: 15px;
    line-height: 1.55;
    color: var(--fg-3);
    margin: 0;
    flex: 1;
  }
  .product-cta {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--fg-2);
    margin-top: 8px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: color var(--dur-med) var(--ease-std), gap var(--dur-med) var(--ease-out);
  }
  .product-card:hover .product-cta {
    color: var(--cnc-accent);
    gap: 10px;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 4px 9px 3px;
    border-radius: var(--radius-xs);
    align-self: flex-start;
  }
  .chip-accent {
    color: var(--cnc-accent);
    border: 1px solid var(--cnc-accent);
    background: rgba(217, 96, 31, 0.06);
  }
  .chip-neutral {
    color: var(--fg-3);
    border: 1px solid var(--line-2);
    background: var(--bg-3);
  }
  .home-story {
    padding: clamp(72px, 10vw, 120px) 0;
    border-top: 1px solid var(--line-1);
  }
  .story-inner {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 56px;
    align-items: center;
  }
  .story-copy { max-width: 640px; }
  .story-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(34px, 4.4vw, 56px);
    line-height: 1.04;
    letter-spacing: -0.005em;
    text-transform: uppercase;
    color: var(--fg-1);
    margin: 14px 0 24px;
  }
  .story-body {
    font-size: 17px;
    line-height: 1.6;
    color: var(--fg-2);
    margin: 0 0 24px;
  }
  .story-pull {
    margin: 28px 0;
    padding: 6px 0 6px 18px;
    border-left: 3px solid var(--cnc-accent);
    font-family: var(--font-display);
    font-weight: 600;
    text-transform: uppercase;
    color: var(--cnc-accent);
    font-size: clamp(18px, 2vw, 24px);
    letter-spacing: 0.01em;
    line-height: 1.2;
  }

  .story-stats {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--line-2);
    border-radius: var(--radius-md);
    background: linear-gradient(180deg, var(--bg-2), var(--bg-3));
    padding: 28px 28px;
    box-shadow: var(--shadow-card);
  }
  .stat {
    padding: 10px 0;
    text-align: center;
  }
  .stat-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(56px, 6vw, 84px);
    line-height: 0.95;
    letter-spacing: -0.01em;
    color: var(--cnc-accent);
    text-shadow: 0 0 28px var(--cnc-accent-glow);
  }
  .stat-num-text {
    font-size: clamp(40px, 4.6vw, 64px);
  }
  .stat-plus {
    font-size: 0.7em;
    margin-left: 2px;
    color: var(--cnc-accent);
  }
  .stat-label {
    margin-top: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fg-3);
  }
  .stat-rule {
    height: 1px;
    background: var(--line-2);
    margin: 6px 0;
  }
  .home-features {
    padding: clamp(72px, 10vw, 120px) 0;
    border-top: 1px solid var(--line-1);
  }
  .wyg-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .wyg-tile {
    padding: 4px 0;
    border-top: 1px solid var(--line-1);
    padding-top: 24px;
    position: relative;
  }
  /* A small orange tick at the top of each tile — TNRCalc-style kinetic mark */
  .wyg-tile::before {
    content: "";
    position: absolute;
    top: -1px; left: 0;
    width: 32px; height: 1px;
    background: var(--cnc-accent);
    box-shadow: 0 0 6px var(--cnc-accent-glow);
  }
  .wyg-tile h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--fg-1);
    margin: 8px 0 10px;
  }
  .wyg-tile p {
    font-size: 15px;
    line-height: 1.55;
    color: var(--fg-3);
    margin: 0;
  }
  .wyg-tile .feat-num {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.24em;
    color: var(--cnc-accent);
    text-transform: uppercase;
  }
  .home-notify {
    padding: 56px 0 72px;
    border-top: 1px solid var(--line-1);
    background: var(--bg-0);
  }
  .home-notify-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }
  .home-notify-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--fg-1);
    margin: 0;
  }
  .home-notify-form {
    display: flex;
    gap: 10px;
    align-items: stretch;
  }
  .home-notify-form input {
    background: var(--bg-2);
    border: 1px solid var(--line-2);
    border-radius: var(--radius-md);
    padding: 12px 16px;
    color: var(--fg-1);
    font-family: var(--font-body);
    font-size: 14px;
    min-width: 260px;
    transition: border-color var(--dur-fast) var(--ease-std),
                box-shadow var(--dur-med) var(--ease-std);
  }
  .home-notify-form input::placeholder { color: var(--fg-4); }
  .home-notify-form input:focus {
    outline: none;
    border-color: var(--cnc-accent);
    box-shadow: 0 0 0 3px var(--cnc-accent-glow-soft);
  }
  @media (max-width: 900px) {
    .home-hero { padding: 48px 0 56px; }
    .home-hero-title { font-size: 40px; margin: 16px 0 14px; }
    .home-hero-sub { font-size: 16px; margin: 0 auto 28px; }
    .home-hero-ctas { margin-bottom: 36px; }
    .products-grid { grid-template-columns: 1fr; gap: 14px; }
    .story-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .story-stats {
      max-width: 420px;
      margin: 0 auto;
      width: 100%;
    }
    .wyg-grid { grid-template-columns: 1fr; gap: 16px; }
    .home-notify-inner { flex-direction: column; align-items: stretch; }
    .home-notify-form { flex-direction: column; }
    .home-notify-form input { min-width: 0; }
  }
</style>
