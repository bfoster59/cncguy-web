---
---
<section class="hero grid-bg">
  <div class="container">
    <span class="eyebrow-line accent">Product · CNCGuy Edit</span>

    <h1 class="hero-title">
      CNCGuy Edit<span class="beta-chip">Beta</span>
    </h1>

    <p class="hero-sub">
      A fast, modern G-code editor with built-in backplot. Made by a machinist.
    </p>

    <div class="hero-cta-group">
      <div>
        <a href="#download" class="cta-primary large">Download for Windows (Free Beta)</a>
      </div>
      <p class="fine-print">
        Free beta through October 2026. After beta, Basic stays free; Pro features require a license.
      </p>
    </div>

    <div class="chrome">
      <div class="chrome-bar">
        <div class="chrome-dots">
          <span></span><span></span><span></span>
        </div>
        <div class="chrome-title">CNCGuy Edit [Beta] · 660-104485-G71.cnc</div>
      </div>
      <img src="/cncguy-edit-screenshot.png" alt="CNCGuy Edit — G-code editor with live backplot" />
    </div>

    <div class="hero-measure">
      <span class="measure-rule">00 — 002 · v0.5 Beta</span>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 96px 0 88px;
    border-bottom: 1px solid var(--line-1);
  }
  .hero-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(48px, 6vw, 62px);
    line-height: 1.02;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: var(--fg-1);
    margin: 22px 0 18px;
  }
  .hero-sub {
    font-size: 19px;
    color: var(--fg-2);
    max-width: 560px;
    margin: 0 0 32px;
    line-height: 1.5;
  }
  .hero-cta-group {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 56px;
  }
  .hero-measure {
    margin-top: 24px;
  }
  @media (max-width: 900px) {
    .hero {
      padding: 48px 0 56px;
    }
    .hero-title {
      font-size: 40px;
      margin: 16px 0 14px;
    }
    .hero-sub {
      font-size: 16px;
      margin: 0 0 26px;
    }
    .hero-cta-group {
      margin-bottom: 40px;
    }
    .hero-measure {
      margin-top: 18px;
    }
  }
</style>
