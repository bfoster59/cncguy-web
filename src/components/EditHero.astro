---
import SectionEnd from './SectionEnd.astro';
---
<section class="hero grid-bg">
  <div class="container">
    <span class="eyebrow-line accent">Product · CNCGuy Edit</span>

    <h1 class="hero-title">
      CNCGuy Edit<span class="beta-chip">Beta</span>
    </h1>

    <p class="hero-sub">
      A fast, modern G-code editor with built-in backplot. Made by a machinist.
    </p>

    <div class="hero-cta-group">
      <div>
        <a href="#download" class="cta-primary large">Download CNCGuy Edit →</a>
      </div>
      <p class="fine-print">
        Free beta through October 2026. After beta, Basic stays free; Pro features require a license.
      </p>
    </div>

    <div class="chrome">
      <div class="chrome-bar">
        <div class="chrome-dots">
          <span></span><span></span><span></span>
        </div>
        <div class="chrome-title">CNCGuy Edit [Beta] · 660-104485-G71.cnc</div>
      </div>
      <img src="/cncguy-edit-screenshot.png" alt="CNCGuy Edit — G-code editor with live backplot" />
    </div>

    <div class="hero-measure">
      <span class="measure-rule">00 — 002 · v0.5 Beta</span>
    </div>
  </div>
  <SectionEnd code="M01" />
</section>

<style>
  .hero {
    padding: 104px 0 96px;
    border-bottom: 1px solid var(--line-1);
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 50% 35% at 25% 0%, rgba(217,96,31,0.10), transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  .hero > .container { position: relative; z-index: 1; }
  .hero-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(48px, 6.5vw, 68px);
    line-height: 1.02;
    letter-spacing: -0.015em;
    text-transform: uppercase;
    color: var(--fg-1);
    margin: 22px 0 18px;
  }
  .hero-sub {
    font-size: 19px;
    color: var(--fg-2);
    max-width: 580px;
    margin: 0 0 36px;
    line-height: 1.5;
  }
  .hero-cta-group {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 64px;
  }
  /* Constrain the screenshot — never upscale, keep crisp */
  .hero .chrome {
    max-width: 1040px;
    margin-left: auto;
    margin-right: auto;
  }
  .hero-measure {
    margin-top: 28px;
  }
  @media (max-width: 900px) {
    .hero {
      padding: 48px 0 56px;
    }
    .hero-title {
      font-size: 40px;
      margin: 16px 0 14px;
    }
    .hero-sub {
      font-size: 16px;
      margin: 0 0 26px;
    }
    .hero-cta-group {
      margin-bottom: 40px;
    }
    .hero-measure {
      margin-top: 18px;
    }
  }
</style>
