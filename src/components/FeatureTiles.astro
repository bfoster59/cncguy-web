---
import SectionEnd from './SectionEnd.astro';
const features = [
  {
    n: '01',
    title: 'Multi-tab Monaco editor',
    body: 'G-code syntax highlighting, find/replace, go-to-line. The editor you wish was in your CAM software.',
    icon: 'tabs',
  },
  {
    n: '02',
    title: '2D backplot for mill + lathe',
    body: 'See the toolpath as you write. Canvas rendering, no 3D plugin bloat.',
    icon: 'toolpath',
  },
  {
    n: '03',
    title: 'Compact Fanuc syntax',
    body: 'Handles N1G20G53X0.Z-15. and spaced styles equally well.',
    icon: 'syntax',
  },
  {
    n: '04',
    title: 'Canned-cycle aware',
    body: 'G71 Type II, G72, G73 profiles, G76 threading, G81–G89 drills — parsed the way Fanuc intends, no phantom moves.',
    icon: 'cycle',
  },
  {
    n: '05',
    title: 'Machine-limit validation',
    body: "Set your machine's travel. Catch over-travel before you crash a fixture.",
    icon: 'limits',
  },
  {
    n: '06',
    title: 'Program transforms',
    body: 'Translate, mirror, rotate the whole program. One click.',
    icon: 'transform',
  },
  {
    n: '07',
    title: 'Open All Recent',
    body: 'Reopen every file from your last job in one click.',
    icon: 'recent',
  },
  {
    n: '08',
    title: 'Drag and drop',
    body: "Drop files from Explorer onto the window. Works the way you'd expect it to.",
    icon: 'drop',
  },
];
---
<section class="features" id="features">
  <div class="container">
    <div class="section-heading">
      <span class="eyebrow-line">01 · What It Does</span>
      <h2>A focused set of tools.</h2>
      <p>No feature bloat, no configuration maze. Eight things, done well.</p>
    </div>

    <div class="features-grid">
      {features.map((f) => (
        <div class="feat-tile">
          <span class="feat-icon" aria-hidden="true">
            {f.icon === 'tabs' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 8h4l1.2-2.2h4L13.5 8H21v11H3z"/>
                <path d="M3 12h18"/>
              </svg>
            )}
            {f.icon === 'toolpath' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 18h18"/>
                <path d="M3 18c3-10 7-10 9-4s5 6 9-2"/>
                <circle cx="3" cy="18" r="1.3" fill="currentColor"/>
                <circle cx="21" cy="12" r="1.3" fill="currentColor"/>
              </svg>
            )}
            {f.icon === 'syntax' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M8 5l-4 7 4 7M16 5l4 7-4 7"/>
                <path d="M13 5l-2 14" stroke-dasharray="2 2"/>
              </svg>
            )}
            {f.icon === 'cycle' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="8"/>
                <path d="M12 4v4M12 16v4M4 12h4M16 12h4"/>
                <circle cx="12" cy="12" r="2"/>
              </svg>
            )}
            {f.icon === 'limits' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="4" y="4" width="16" height="16"/>
                <path d="M4 9h16M4 15h16M9 4v16M15 4v16" stroke-dasharray="2 2"/>
              </svg>
            )}
            {f.icon === 'transform' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M5 7h10l-2-2M5 7l2 2"/>
                <path d="M19 17H9l2 2M19 17l-2-2"/>
              </svg>
            )}
            {f.icon === 'recent' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="8"/>
                <path d="M12 7v5l3 2"/>
              </svg>
            )}
            {f.icon === 'drop' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 7h6l2 2h8v10H4z" stroke-dasharray="3 2"/>
                <path d="M12 4v7M9 8l3 3 3-3"/>
              </svg>
            )}
          </span>
          <div class="feat-num">Feature · {f.n}</div>
          <h3>{f.title}</h3>
          <p>{f.body}</p>
        </div>
      ))}
    </div>
  </div>
  <SectionEnd code="M01" />
</section>

<style>
  .features {
    padding: clamp(72px, 10vw, 120px) 0;
  }
  .features-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }
  @media (max-width: 900px) {
    .features {
      padding: 64px 0;
    }
    .features-grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }
  }
</style>
